# Letters From Your Future Self — environment reference
# No AI keys are needed. Letters come from a pre-written bank (letters.json).
#
# In n8n these values live in credentials / node fields (see SETUP.md) — this
# file is just a reference of what you need.

# Resend API key — resend.com -> API Keys. Starts with re_
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Sheet ID — the long id in your sheet URL between /d/ and /edit
SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789

# Sender identity (the domain must be verified in Resend)
MAIL_FROM=Your Future Self · High Conscious Life <letters@highconsciouslife.in>
